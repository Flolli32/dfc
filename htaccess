# .htaccess für Galerie
# Diese Datei aktiviert PHP und verbessert die Performance

# PHP aktivieren (falls nicht standard)
<FilesMatch "\.(php)$">
    SetHandler application/x-httpd-php
</FilesMatch>

# Alternative PHP-Handler (falls oben nicht funktioniert, kommentiere eine Zeile ein):
# AddHandler application/x-httpd-php5 .php
# AddHandler application/x-httpd-php7 .php
# AddHandler application/x-httpd-php8 .php

# PHP-Einstellungen (optional, kann auskommentiert werden)
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>

# Kompression aktivieren (Performance)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser-Caching für Bilder
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>

# Sicherheit: Verhindere Directory Listing
Options -Indexes

# Sicherheit: Schütze sensible Dateien
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
