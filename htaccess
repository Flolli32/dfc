# .htaccess für Galerie
# Diese Datei aktiviert PHP und verbessert die Performance

# PHP aktivieren (falls nicht standard)
<FilesMatch "\.(php)$">
    SetHandler application/x-httpd-php
</FilesMatch>

# Alternative PHP-Handler (falls oben nicht funktioniert, kommentiere eine Zeile ein):
# AddHandler application/x-httpd-php5 .php
# AddHandler application/x-httpd-php7 .php
# AddHandler application/x-httpd-php8 .php

# PHP-Einstellungen (optional, kann auskommentiert werden)
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>

# Kompression aktivieren (Performance)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser-Caching für Bilder
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>

# Sicherheit: HTTP Security-Header
<IfModule mod_headers.c>
    # Verhindert MIME-Type-Sniffing
    Header set X-Content-Type-Options "nosniff"
    # Schutz vor Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    # Referrer nur an gleiche Herkunft / bei Downgrade nichts
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Schraenkt Browser-Features ein
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS: erzwingt HTTPS (1 Jahr). Nur aktivieren wenn Seite dauerhaft per HTTPS laeuft.
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Content-Security-Policy: erlaubt YouTube-Embeds + Inline-Styles/Scripts der Seite
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.youtube.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; frame-src https://www.youtube-nocookie.com https://www.youtube.com; connect-src 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

# Sicherheit: Verhindere Directory Listing
Options -Indexes

# Sicherheit: Schütze sensible Dateien
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
